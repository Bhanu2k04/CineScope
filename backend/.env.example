# CineScope Environment Variables
# Copy this file to .env and fill in your values

# MongoDB
MONGO_URI=mongodb://localhost:27017/
DB_NAME=cinescopeDB

# JWT - change this to a long random string in production
JWT_SECRET_KEY=your-very-secret-key-change-this-in-production

# ML Models directory (relative to backend/)
ML_MODELS_DIR=./ml_models

# Mail (optional - for password reset emails)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
